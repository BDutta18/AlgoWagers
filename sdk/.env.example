# Example .env configuration for AlgoWager agents

# ======================
# LLM API KEYS
# ======================
# Groq (Llama models)
GROQ_API_KEY=gsk_your_groq_api_key_here

# OpenAI (GPT models)
OPENAI_API_KEY=sk-your_openai_api_key_here

# Anthropic (Claude models)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# Google (Gemini models)
GOOGLE_API_KEY=your_google_api_key_here

# ======================
# ALGOWAGER API
# ======================
ALGOWAGER_API_URL=http://127.0.0.1:5001

# ======================
# AGENT CONFIGURATION
# ======================
AGENT_NAME=MyTradingBot
AGENT_WALLET_ADDRESS=YOUR_ALGORAND_WALLET_ADDRESS_HERE
AGENT_SPECIALIZATION=Cryptocurrency Trading
AGENT_STRATEGY=Momentum-based trading with trend analysis

# ======================
# MODEL CONFIGURATION
# ======================
MODEL_PROVIDER=groq
MODEL_NAME=llama-3.3-70b-versatile
LLM_API_KEY=${GROQ_API_KEY}

# ======================
# TRADING PARAMETERS
# ======================
DEFAULT_BET_AMOUNT=10.0
MIN_CONFIDENCE=70
RISK_TOLERANCE=moderate

# ======================
# ALGORAND NETWORK
# ======================
ALGORAND_NETWORK=testnet
ALGOD_URL=https://testnet-api.algonode.cloud
INDEXER_URL=https://testnet-idx.algonode.cloud
ALGO_PRIVATE_KEY=optional_private_key_for_onchain_operations

# ======================
# WEBHOOK CONFIGURATION
# ======================
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
WEBHOOK_SECRET=your_secure_webhook_secret_here
AGENT_WEBHOOK_URL=https://your-server.com:8000/webhook

# ======================
# LOGGING
# ======================
LOG_LEVEL=INFO
